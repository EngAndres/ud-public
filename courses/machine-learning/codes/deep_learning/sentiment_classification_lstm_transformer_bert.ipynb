    "# ── Train BERT ────────────────────────────────────────────────────────────────\n",
    "def train_epoch_bert(model, loader, optimizer):\n",
    "    model.train()\n",
    "    total_loss, total_correct, total = 0.0, 0, 0\n",
    "    for ids, mask, y in loader:\n",
    "        ids, mask, y = ids.to(DEVICE), mask.to(DEVICE), y.to(DEVICE)\n",
    "        optimizer.zero_grad()\n",
    "        outputs = model(input_ids=ids, attention_mask=mask, labels=y)\n",
    "        loss = outputs.loss\n",
    "        loss.backward()\n",
    "        nn.utils.clip_grad_norm_(model.parameters(), max_norm=1.0)\n",
    "        optimizer.step()\n",
    "        total_loss += loss.item() * y.size(0)\n",
    "        total_correct += (outputs.logits.argmax(1) == y).sum().item()\n",
    "        total += y.size(0)\n",
    "    return total_loss / total, total_correct / total\n",
    "\n",
    "\n",
    "def eval_bert(model, loader):\n",
    "    model.eval()\n",
    "    total_loss, total_correct, total = 0.0, 0, 0\n",
    "    with torch.no_grad():\n",
    "        for ids, mask, y in loader:\n",
    "            ids, mask, y = ids.to(DEVICE), mask.to(DEVICE), y.to(DEVICE)\n",
    "            outputs = model(input_ids=ids, attention_mask=mask, labels=y)\n",
    "            total_loss += outputs.loss.item() * y.size(0)\n",
    "            total_correct += (outputs.logits.argmax(1) == y).sum().item()\n",
    "            total += y.size(0)\n",
    "    return total_loss / total, total_correct / total\n",
    "\n",
    "\n",
    "bert_optimizer = optim.AdamW(bert_model.parameters(), lr=2e-5)\n",
    "\n",
    "history_bert = {'train_loss': [], 'train_acc': [], 'val_loss': [], 'val_acc': []}\n",
    "print('\\n── Training Model C — BERT ──')\n",
    "for epoch in range(1, EPOCHS + 1):\n",
    "    t0 = time.time()\n",
    "    tr_loss, tr_acc = train_epoch_bert(bert_model, train_loader_bert, bert_optimizer)\n",
    "    vl_loss, vl_acc = eval_bert(bert_model, test_loader_bert)\n",
    "    history_bert['train_loss'].append(tr_loss)\n",
    "    history_bert['train_acc'].append(tr_acc)\n",
    "    history_bert['val_loss'].append(vl_loss)\n",
    "    history_bert['val_acc'].append(vl_acc)\n",
    "    print(f'  Epoch {epoch}/{EPOCHS}  '\n",
    "          f'train loss={tr_loss:.4f} acc={tr_acc:.3f}  |  '\n",
    "          f'val loss={vl_loss:.4f} acc={vl_acc:.3f}  '\n",
    "          f'({time.time()-t0:.1f}s)')\n"
   ]
