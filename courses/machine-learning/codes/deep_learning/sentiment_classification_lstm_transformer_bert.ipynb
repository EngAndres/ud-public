    "def get_predictions_rnn(model, loader):\n",
    "    model.eval()\n",
    "    all_preds, all_labels = [], []\n",
    "    with torch.no_grad():\n",
    "        for x, y in loader:\n",
    "            preds = model(x.to(DEVICE)).argmax(1).cpu().tolist()\n",
    "            all_preds.extend(preds)\n",
    "            all_labels.extend(y.tolist())\n",
    "    return all_preds, all_labels\n",
    "\n",
    "\n",
    "def get_predictions_bert(model, loader):\n",
    "    model.eval()\n",
    "    all_preds, all_labels = [], []\n",
    "    with torch.no_grad():\n",
    "        for ids, mask, y in loader:\n",
    "            preds = model(input_ids=ids.to(DEVICE), attention_mask=mask.to(DEVICE)\n",
    "                          ).logits.argmax(1).cpu().tolist()\n",
    "            all_preds.extend(preds)\n",
    "            all_labels.extend(y.tolist())\n",
    "    return all_preds, all_labels\n",
    "\n",
    "\n",
    "def compute_metrics(preds, labels, name):\n",
    "    acc  = accuracy_score(labels, preds)\n",
    "    prec = precision_score(labels, preds, zero_division=0)\n",
    "    rec  = recall_score(labels, preds, zero_division=0)\n",
    "    print(f'  {name:<20}  Accuracy={acc:.4f}  Precision={prec:.4f}  Recall={rec:.4f}')\n",
    "    return {'model': name, 'accuracy': acc, 'precision': prec, 'recall': rec}\n",
    "\n",
    "\n",
    "print('\\n══ Test-Set Metrics ══')\n",
    "results = []\n",
    "for model, loader, name, fn in [\n",
    "    (lstm_model,        test_loader_rnn,  'Model A — LSTM',        get_predictions_rnn),\n",
    "    (transformer_model, test_loader_rnn,  'Model B — Transformer', get_predictions_rnn),\n",
    "    (bert_model,        test_loader_bert, 'Model C — BERT',        get_predictions_bert),\n",
    "]:\n",
    "    preds, labels = fn(model, loader)\n",
    "    results.append(compute_metrics(preds, labels, name))\n"
   ]
  },
