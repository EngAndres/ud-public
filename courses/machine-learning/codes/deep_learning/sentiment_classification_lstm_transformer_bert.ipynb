    "---\n",
    "## Section 3 — Preprocess & Tokenize Text\n",
    "Two pipelines:\n",
    "- **LSTM / Transformer (from scratch):** vocabulary built from training data, integer sequences, padding.\n",
    "- **BERT:** HuggingFace `BertTokenizerFast` with automatic truncation/padding to 256 tokens.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "78c1ff38",
   "metadata": {},
   "outputs": [],
   "source": [
    "import re\n",
    "\n",
    "# ── Shared hyper-parameters ──────────────────────────────────────────────────\n",
    "MAX_LEN    = 256    # max token length for all models\n",
    "BATCH_SIZE = 64\n",
    "VOCAB_SIZE = 20_000  # for LSTM / Transformer from-scratch\n",
    "\n",
    "# ── Simple tokenizer ─────────────────────────────────────────────────────────\n",
    "def simple_tokenize(text: str):\n",
    "    text = text.lower()\n",
    "    text = re.sub(r'<[^>]+>', ' ', text)   # strip HTML\n",
    "    text = re.sub(r'[^a-z0-9\\s]', ' ', text)\n",
    "    return text.split()\n",
    "\n",
    "# Build vocabulary from training data\n",
    "all_tokens = []\n",
    "for item in train_raw:\n",
    "    all_tokens.extend(simple_tokenize(item['text']))\n",
    "\n",
    "token_counts = Counter(all_tokens)\n",
    "vocab = ['<PAD>', '<UNK>'] + [tok for tok, _ in token_counts.most_common(VOCAB_SIZE - 2)]\n",
    "word2idx = {w: i for i, w in enumerate(vocab)}\n",
    "PAD_IDX = word2idx['<PAD>']\n",
    "UNK_IDX = word2idx['<UNK>']\n",
    "\n",
    "print(f'Vocabulary size: {len(vocab)}')\n",
    "\n",
    "def encode(text: str):\n",
    "    tokens = simple_tokenize(text)[:MAX_LEN]\n",
    "    ids = [word2idx.get(t, UNK_IDX) for t in tokens]\n",
    "    # Pad / truncate\n",
    "    ids = ids + [PAD_IDX] * (MAX_LEN - len(ids))\n",
    "    return ids\n",
    "\n",
    "# ── Dataset class for LSTM / Transformer ─────────────────────────────────────\n",
    "class TextDataset(Dataset):\n",
    "    def __init__(self, hf_split):\n",
    "        self.texts  = [encode(item['text']) for item in hf_split]\n",
    "        self.labels = [item['label'] for item in hf_split]\n",
    "\n",
    "    def __len__(self):\n",
    "        return len(self.labels)\n",
    "\n",
    "    def __getitem__(self, idx):\n",
    "        return (\n",
    "            torch.tensor(self.texts[idx],  dtype=torch.long),\n",
    "            torch.tensor(self.labels[idx], dtype=torch.long),\n",
    "        )\n",
    "\n",
    "train_ds_rnn = TextDataset(train_raw)\n",
    "test_ds_rnn  = TextDataset(test_raw)\n",
    "\n",
    "train_loader_rnn = DataLoader(train_ds_rnn, batch_size=BATCH_SIZE, shuffle=True)\n",
    "test_loader_rnn  = DataLoader(test_ds_rnn,  batch_size=BATCH_SIZE)\n",
    "\n",
    "print(f'RNN / Transformer loaders ready. Batches in train: {len(train_loader_rnn)}')\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "8b76a032",
   "metadata": {},
   "outputs": [],
   "source": [
    "from transformers import BertTokenizerFast\n",
    "\n",
    "bert_tokenizer = BertTokenizerFast.from_pretrained('bert-base-uncased')\n",
    "\n",
    "class BertDataset(Dataset):\n",
    "    def __init__(self, hf_split):\n",
    "        texts  = [item['text'] for item in hf_split]\n",
    "        labels = [item['label'] for item in hf_split]\n",
    "        # Tokenize without return_tensors='pt' to avoid transformers internal\n",
    "        # torch-detection issue, then convert manually with torch.tensor().\n",
    "        enc = bert_tokenizer(\n",
    "            texts,\n",
    "            truncation=True, padding='max_length',\n",
    "            max_length=MAX_LEN,\n",
    "        )\n",
    "        self.input_ids      = torch.tensor(enc['input_ids'],      dtype=torch.long)\n",
    "        self.attention_mask = torch.tensor(enc['attention_mask'], dtype=torch.long)\n",
    "        self.labels         = torch.tensor(labels,                dtype=torch.long)\n",
    "\n",
    "    def __len__(self):\n",
    "        return len(self.labels)\n",
    "\n",
    "    def __getitem__(self, idx):\n",
    "        return self.input_ids[idx], self.attention_mask[idx], self.labels[idx]\n",
    "\n",
    "print('Tokenizing for BERT ...')\n",
    "train_ds_bert = BertDataset(train_raw)\n",
    "test_ds_bert  = BertDataset(test_raw)\n",
    "\n",
    "train_loader_bert = DataLoader(train_ds_bert, batch_size=16, shuffle=True)\n",
    "test_loader_bert  = DataLoader(test_ds_bert,  batch_size=16)\n",
    "\n",
    "print(f'BERT loaders ready. Batches in train: {len(train_loader_bert)}')\n"
   ]
  },
