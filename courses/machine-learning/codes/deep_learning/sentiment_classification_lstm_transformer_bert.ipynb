    "import sys, subprocess\n",
    "\n",
    "# The ml_old pyenv has a partially-broken transformers install where:\n",
    "#   1. is_torch_available() returns False (torch not on its PATH)\n",
    "#   2. modeling_bert tries to import GenerationMixin that doesn't exist\n",
    "# Fix: purge all stale transformers entries from sys.modules, install\n",
    "# a known-good version for torch 2.2.2 / Python 3.11 macOS, then reimport.\n",
    "print('Removing stale transformers modules from sys.modules ...')\n",
    "stale = [k for k in list(sys.modules) if k.startswith('transformers')]\n",
    "for mod in stale:\n",
    "    del sys.modules[mod]\n",
    "\n",
    "print('Installing compatible transformers version ...')\n",
    "subprocess.check_call(\n",
    "    [sys.executable, '-m', 'pip', 'install', '-q',\n",
    "     'transformers>=4.35,<4.47', '--prefer-binary']\n",
    ")\n",
    "\n",
    "from transformers import BertForSequenceClassification\n",
    "\n",
    "bert_model = BertForSequenceClassification.from_pretrained(\n",
    "    'bert-base-uncased', num_labels=2\n",
    ").to(DEVICE)\n",
    "\n",
    "total_params = sum(p.numel() for p in bert_model.parameters() if p.requires_grad)\n",
    "print(f'Model C — BERT | trainable parameters: {total_params:,}')\n",
    "print(f'  (bert-base-uncased: 12 Transformer layers, 768 hidden, 12 heads)')\n"
   ]
