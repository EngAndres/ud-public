    "---\n",
    "## Section 4 — Model A: 2-Layer Bidirectional LSTM (Baseline)\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "8bd4bdb3",
   "metadata": {},
   "outputs": [],
   "source": [
    "class LSTMClassifier(nn.Module):\n",
    "    \"\"\"2-layer bidirectional LSTM with embedding and FC classification head.\"\"\"\n",
    "\n",
    "    def __init__(self, vocab_size, embed_dim=128, hidden_dim=256,\n",
    "                 num_layers=2, num_classes=2, dropout=0.3, pad_idx=0):\n",
    "        super().__init__()\n",
    "        self.embedding = nn.Embedding(vocab_size, embed_dim, padding_idx=pad_idx)\n",
    "        self.lstm = nn.LSTM(\n",
    "            embed_dim, hidden_dim,\n",
    "            num_layers=num_layers,\n",
    "            batch_first=True,\n",
    "            bidirectional=True,\n",
    "            dropout=dropout if num_layers > 1 else 0.0,\n",
    "        )\n",
    "        self.dropout = nn.Dropout(dropout)\n",
    "        # bidirectional: hidden_dim * 2\n",
    "        self.fc = nn.Linear(hidden_dim * 2, num_classes)\n",
    "\n",
    "    def forward(self, x):\n",
    "        embedded = self.dropout(self.embedding(x))   # (B, L, E)\n",
    "        _, (hidden, _) = self.lstm(embedded)         # hidden: (2*layers, B, H)\n",
    "        # Concatenate last forward and backward hidden states\n",
    "        out = torch.cat([hidden[-2], hidden[-1]], dim=1)  # (B, 2H)\n",
    "        return self.fc(self.dropout(out))\n",
    "\n",
    "lstm_model = LSTMClassifier(len(vocab), pad_idx=PAD_IDX).to(DEVICE)\n",
    "total_params = sum(p.numel() for p in lstm_model.parameters() if p.requires_grad)\n",
    "print(f'Model A — LSTM | trainable parameters: {total_params:,}')\n",
    "print(lstm_model)\n"
   ]
  },
  {
